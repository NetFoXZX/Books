{
  "manifest_version": 3,
  "name": "Yandex Books Downloader by NeTFoXZX",
  "version": "1.0.9",
  "description": "Скачивайте книги с Yandex Books в формате EPUB и MP3",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://books.yandex.ru/*",
    "https://yandex.ru/books/*",
    "https://audio.bookmate.ru/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://books.yandex.ru/*",
        "https://yandex.ru/books/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}